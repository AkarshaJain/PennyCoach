# ---- Database ----
# Local SQLite (default, zero-setup):
DATABASE_URL="file:./dev.db"

# Production Postgres on Neon / Supabase (free tier). Example:
# DATABASE_URL="postgresql://user:password@ep-xyz.neon.tech/neondb?sslmode=require"

# ---- App ----
# Default profile currency (ISO 4217) and locale. Change these if you live
# outside the US — e.g. INR + en-IN, GBP + en-GB, EUR + en-IE.
APP_DEFAULT_CURRENCY="USD"
APP_DEFAULT_LOCALE="en-US"
